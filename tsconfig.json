{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": false,
    "declaration": false,
    "types": ["vite/client", "node"]
  },
  "include": ["server-src/**/*", "vite.config.ts"],
  "exclude": ["node_modules", "assets"]
}
