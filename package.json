{
  "name": "lukaisu-server",
  "version": "0.1.0",
  "description": "Lukaisu Server - A self-hosted language learning application for reading-based vocabulary acquisition",
  "type": "module",
  "main": "index.js",
  "homepage": "https://hugofara.github.io/lukaisu-server/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lukaisu/lukaisu-server.git"
  },
  "bugs": {
    "url": "https://github.com/lukaisu/lukaisu-server/issues"
  },
  "author": {
    "name": "HugoFara",
    "url": "https://github.com/HugoFara"
  },
  "contributors": [
    {
      "name": "lang-learn-guy",
      "url": "https://sourceforge.net/u/lang-learn-guy/profile/"
    }
  ],
  "license": "Unlicense",
  "keywords": [
    "lukaisu-server",
    "language-learning",
    "spaced-repetition",
    "vocabulary",
    "reading",
    "self-hosted",
    "education"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:app": "vite build --config vite.app.config.ts",
    "build:themes": "node scripts/build-themes.js",
    "build:pwa-icons": "node scripts/generate-pwa-icons.js",
    "build:all": "npm run build && npm run build:themes",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "e2e": "cypress run",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "docs:dev": "node scripts/docs-pre-build.js && vitepress dev docs-src",
    "docs:build": "node scripts/docs-pre-build.js && vitepress build docs-src",
    "docs:preview": "vitepress preview docs-src"
  },
  "dependencies": {
    "@alpinejs/csp": "^3.15.2",
    "@yaireo/tagify": "^4.35.6",
    "bulma": "^1.0.4",
    "chart.js": "^4.5.1",
    "dexie": "^4.2.1",
    "lucide": "^1.7.0"
  },
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "esbuild": ">=0.25.0",
    "tmp": ">=0.2.6",
    "systeminformation": ">=5.31.6",
    "brace-expansion": ">=5.0.6",
    "vitepress": {
      "vite": "^6.4.2"
    }
  },
  "devDependencies": {
    "@eslint/css": "^1.1.0",
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^8.0.1",
    "@types/alpinejs": "^3.13.11",
    "@types/node": "^25.5.2",
    "@types/yaireo__tagify": "^4.27.0",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@vitest/coverage-v8": "^4.0.14",
    "cypress": "^15.16.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.1",
    "prettier": "^3.6.2",
    "purgecss": "^4.1.3",
    "typedoc": "^0.28.16",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.48.0",
    "vite": "^8.0.7",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.14",
    "vue": "^3.5.25"
  }
}
